{
    "rules": [
        {"name": "bearer-like-token",
        "pattern": "eyJ[a-zA-Z0-9_-]{10,}",
        "importance": "HIGH",
        "log": "Bearer-token was found!"},

        {"name": "aws-key-id",
        "pattern": "AKIA[0-9A-Z]{16}",
        "importance": "HIGH",
        "log": "AWS Access Key ID was found!"},

        {"name": "stripe-secret-key",
        "pattern": "sk_(live|test)_[0-9a-zA-Z]{24,}",
        "importance": "HIGH",
        "log": "Stripe Secret Key was found!"},

        {"name": "google-api-key",
        "pattern": "AIza[0-9A-Za-z\\-_]{35}",
        "importance": "HIGH",
        "log": "Google API Key was found!"},

        {"name": "github-token",
        "pattern": "gh[pousr]_[0-9a-zA-Z]{36}",
        "importance": "HIGH",
        "log": "Github-token was found!"},

        {"name": "phone-number",
        "pattern": "\\+7[0-9]{10}",
        "importance": "LOW",
        "log": "Phone number was found!"},

        {"name": "email",
        "pattern": "[\\w.-]+@[\\w.-]+\\.\\w+",
        "importance": "LOW",
        "log": "Email was found!"},

        {"name": "passport",
        "pattern": "\\b\\d{4}\\s?\\d{6}\\b",
        "importance": "MEDIUM",
        "log": "Russian passport was found!"}
    ]
}
